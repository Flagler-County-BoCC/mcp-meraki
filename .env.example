# Cisco Meraki Dashboard API credentials
# Generate an API key in the dashboard: Organization > Settings > Dashboard API access
MERAKI_API_KEY=CHANGE_ME

# Base URL for the Meraki API (region-specific shards also work, e.g. https://api.meraki.com/api/v1)
MERAKI_BASE_URL=https://api.meraki.com/api/v1

# Request timeout in milliseconds
MERAKI_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
NODE_ENV=development
